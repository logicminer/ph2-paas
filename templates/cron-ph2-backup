# PH2 daily backup cron — generated by bootstrap.sh → /etc/cron.d/ph2-backup
# Retention: 7 daily + 4 weekly (Sundays promoted, kept 28 days)
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Daily at 02:00
0 2 * * * root __SCRIPTS_DIR__/backup.sh >> /var/log/ph2-backup.log 2>&1
