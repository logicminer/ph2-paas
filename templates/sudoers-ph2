# PH2 PaaS sudoers — allows the panel to run operational scripts as root.
# The __USER__ placeholder is replaced by bootstrap.sh with the panel user.
# Generated by bootstrap.sh → /etc/sudoers.d/ph2

# Allow spawn/destroy/backup/restore scripts to run as root (panel automation)
__USER__ ALL=(root) NOPASSWD: __SCRIPTS_DIR__/spawn-wp.sh
__USER__ ALL=(root) NOPASSWD: __SCRIPTS_DIR__/destroy-wp.sh
__USER__ ALL=(root) NOPASSWD: __SCRIPTS_DIR__/backup.sh
__USER__ ALL=(root) NOPASSWD: __SCRIPTS_DIR__/restore.sh
