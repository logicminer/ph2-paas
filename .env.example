# ─── PH2 PaaS — Environment Configuration ────────────────────────────────────
# Copy to .env and fill in. bootstrap.sh reads this file.
# Lines marked [AUTO] are auto-generated by bootstrap if left blank.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloudflare (required) ────────────────────────────────────────────────────
# Your Cloudflare account ID (dashboard → right sidebar)
CLOUDFLARE_ACCOUNT_ID=

# API token with: Zone→DNS:Edit, Zone→Cache Purge:Edit, Account→Cloudflare Tunnel:Edit, Account→Access:Apps:Edit
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Note: Cache Purge permission is required for domain takeovers (prevents stale edge cache).
#        See docs/FITRAH-ROUTING-FIX.md for why this matters.
CLOUDFLARE_TOKEN=

# ── Domains (required) ───────────────────────────────────────────────────────
# The base domain under which Dokku auto-generates app subdomains
# (e.g. appname.markethive.life). Must be a zone in your Cloudflare account.
DOKKU_GLOBAL_DOMAIN=markethive.life

# The subdomain for the Portainer management console
PORTAINER_DOMAIN=ph2.markethive.life

# The subdomain for the control panel (this Next.js app)
PANEL_DOMAIN=panel.markethive.life

# ── Admin email for Cloudflare Access gate ───────────────────────────────────
# Only this email can log in to Portainer + the control panel (via email OTP)
ACCESS_ADMIN_EMAIL=bachelors.michael@gmail.com

# ── System paths ─────────────────────────────────────────────────────────────
# Where the operational scripts live (spawn/destroy/backup)
SCRIPTS_DIR=/opt/ph2/scripts

# Where backups are stored
BACKUP_DIR=/data/backups

# ── Docker container names ───────────────────────────────────────────────────
OLS_CONTAINER=litespeed
MARIADB_CONTAINER=mariadb
WP_NETWORK=wp-tier

# ── OpenLiteSpeed versions ───────────────────────────────────────────────────
OLS_VERSION=1.8.5
PHP_VERSION=lsphp85
PHPMYADMIN_VERSION=5.2.3

# ── Memory tier [AUTO] ───────────────────────────────────────────────────────
# Leave blank to auto-detect from installed RAM. Override to force specific sizes.
# ZRAM_SIZE_MB=
# SWAP_SIZE_MB=

# ── Auto-generated secrets [AUTO] ────────────────────────────────────────────
# Leave blank — bootstrap.sh generates these and writes to /etc/ph2/env
# MARIADB_ROOT_PASSWORD=
# OLS_ADMIN_PASSWORD=
# TUNNEL_ID=
